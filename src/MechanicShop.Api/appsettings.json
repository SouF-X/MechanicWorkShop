{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=MechanicShopLearningDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;"
  },
  "FirstManager": {
    "FirstName": "Demo",
    "LastName": "Manager",
    "Email": "manager@localhost",
    "Password": "manager123"
  },
  "AppSettings": {
    "OpeningTime": "09:00",
    "ClosingTime": "17:00",
    "MaxSpots": 4,
    "MinimumAppointmentDurationInMinutes": 30,
    "LocalCacheExpirationInMins": 5,
    "DistributedCacheExpirationMins": 5,
    "DefaultPageNumber": 1,
    "DefaultPageSize": 10,
    "BookingCancellationThresholdMinutes": 15,
    "OverdueBookingCleanupFrequencyMinutes": 3,
    "CorsPolicyName": "MechanicShop",
    "AllowedOrigins": [
      "http://localhost:5121",
      "https://localhost:7041",
      "http://localhost:5001"
    ]
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "api"
    }
  },
  "JwtSettings": {
    "Secret": "development-placeholder-secret-change-in-azure-app-settings-000000",
    "TokenExpirationInMinutes": 60,
    "Issuer": "localhost",
    "Audience": "localhost"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
